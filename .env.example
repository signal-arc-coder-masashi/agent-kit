# agent-kit 環境変数設定
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env

# ── Slack MCP ──────────────────────────────────
# Slack Bot Token（xoxb- から始まる文字列）
# 取得方法: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack Team ID（T から始まる文字列）
# 取得方法: Slack ワークスペース URL の slack.com/client/TXXXXXXXX の T... 部分
SLACK_TEAM_ID=T-your-team-id-here
